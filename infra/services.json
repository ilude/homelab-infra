        "tf_domain": "onramp_host_hostname",
        "user_var": "onramp_host_deploy_user",
        "tf_user": "onramp_host_deploy_user",
        "extra_play_vars": {
          "onramp_host_deploy_dir": "onramp_host_deploy_dir"
