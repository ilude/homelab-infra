        "tf_user": "hermes_ansible_user",
        "extra_play_vars": {
          "hermes_runtime_user": "hermes_runtime_user",
          "hermes_ssh_public_keys": "lxc_ssh_public_keys"
        }
      },
      "terraform_module": "hermes"
    },
    "onramp_host": {
      "state_capable": true,
      "state_order": 4,
      "execution_resource": "onramp_host",
      "playbooks": [
        "infra/ansible/playbooks/onramp-host.yml"
      ],
      "dependencies": [],
      "inventory": {
        "host": "onramp_host_vm",
        "group": "onramp_host",
        "vmid_var": "onramp_host_vmid",
        "tf_vmid": "onramp_host_vmid",
