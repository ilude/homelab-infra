---
use_default_settings: true

server:
  secret_key: "{{ searxng_secret_key }}"
  bind_address: "0.0.0.0"
  port: 8080
{% if searxng_onramp_enable_public_url | bool %}
  base_url: "{{ searxng_public_url }}"
{% endif %}

ui:
  static_use_hash: true
  query_in_title: false

general:
  instance_name: "{{ searxng_onramp_instance_name }}"

search:
  safe_search: 1
  autocomplete: ""
