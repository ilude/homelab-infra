{
    email {{ caddy_email }}
}

{% if caddy_server_names is defined %}
{% set primary_server_names = caddy_server_names %}
{% else %}
{% set primary_server_names = [caddy_server_name] %}
{% endif %}
{{ primary_server_names | join(", ") }} {
    encode zstd gzip
    reverse_proxy {{ caddy_upstream }}

    tls {
        dns cloudflare {env.CF_DNS_API_TOKEN}
        resolvers 1.1.1.1
    }
}
{% for vhost in caddy_extra_vhosts | default([]) %}
{% if vhost.server_names is defined %}
{% set vhost_server_names = vhost.server_names %}
{% else %}
{% set vhost_server_names = [vhost.server_name] %}
{% endif %}

{{ vhost_server_names | join(", ") }} {
    encode zstd gzip
    reverse_proxy {{ vhost.upstream }}

    tls {
        dns cloudflare {env.CF_DNS_API_TOKEN}
        resolvers 1.1.1.1
    }
}
{% endfor %}
