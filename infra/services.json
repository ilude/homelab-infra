{
  "default_services": [
    "technitium",
    "forgejo"
  ],
  "services": {
    "technitium": {
      "execution_resource": "direct_lxc_known_hosts",
      "state_capable": true,
      "state_order": 3,
      "playbooks": [
        "infra/ansible/playbooks/technitium.yml",
        "infra/ansible/playbooks/caddy-proxy.yml",
        "infra/ansible/playbooks/technitium-cluster.yml",
        "infra/ansible/playbooks/technitium-dns.yml"
      ],
      "dependencies": [],
      "inventory": {
        "host": "technitium_dns",
        "group": "technitium",
        "vmid_var": "technitium_vmid",
        "tf_vmid": "technitium_container_vmid",
        "tf_host": "technitium_container_ipv4_address",
        "extra_play_vars": {
          "technitium_cluster_domain": "technitium_cluster_domain",
          "technitium_cluster_enabled": "technitium_cluster_enabled",
          "technitium_keepalived_enabled": "technitium_cluster_enabled",
          "technitium_virtual_ipv4_address": "technitium_virtual_ipv4_address"
        }
      },
      "terraform_module": "technitium_dns"
    },
    "technitium_secondary": {
      "execution_resource": "direct_lxc_known_hosts",
      "state_capable": false,
      "playbooks": [
        "infra/ansible/playbooks/technitium-secondary.yml",
        "infra/ansible/playbooks/caddy-proxy-secondary.yml"
      ],
      "dependencies": [],
      "inventory": {
        "host": "technitium_secondary_dns",
        "group": "technitium_secondary",
        "vmid_var": "technitium_secondary_vmid",
        "tf_vmid": "technitium_secondary_container_vmid",
        "tf_host": "technitium_secondary_container_ipv4_address",
        "pve_group": "pve_secondary",
        "pve_host": "pve_secondary_target",
        "pve_host_env": "SECONDARY_PVE_HOST",
        "tf_pve_node": "secondary_proxmox_node_name",
        "extra_play_vars": {
          "technitium_cluster_domain": "technitium_cluster_domain",
          "technitium_cluster_enabled": "technitium_cluster_enabled",
          "technitium_keepalived_enabled": "technitium_cluster_enabled",
          "technitium_virtual_ipv4_address": "technitium_virtual_ipv4_address"
        }
      },
      "terraform_module": "technitium_secondary_dns"
    },
    "forgejo": {
      "execution_resource": "direct_lxc_known_hosts",
      "state_capable": true,
      "state_order": 2,
      "playbooks": [
        "infra/ansible/playbooks/forgejo.yml"
      ],
      "dependencies": [],
      "inventory": {
        "host": "forgejo_lxc",
        "group": "forgejo",
        "vmid_var": "forgejo_vmid",
        "tf_vmid": "forgejo_container_vmid",
        "tf_host": "forgejo_lan_ip",
        "domain_var": "forgejo_domain",
        "tf_domain": "forgejo_server_name",
        "extra_play_vars": {
          "forgejo_data_host_path": "forgejo_data_host_path",
          "forgejo_data_mount_path": "forgejo_data_mount_path"
        }
      },
      "terraform_module": "forgejo"
    },
    "tailscale_client": {
      "execution_resource": "direct_lxc_known_hosts",
      "state_capable": false,
      "playbooks": [
        "infra/ansible/playbooks/tailscale-client.yml"
      ],
      "dependencies": [],
      "inventory": {
        "host": "tailscale_client",
        "group": "tailscale_client",
        "vmid_var": "tailscale_client_vmid",
        "tf_vmid": "tailscale_client_vmid",
        "tf_host": "tailscale_client_ipv4_address",
        "extra_play_vars": {
          "tailscale_client_enabled": "tailscale_client_enabled"
        }
      },
      "terraform_module": "tailscale_client"
    },
    "forgejo_runner": {
      "state_capable": false,
      "execution_resource": "direct_lxc_known_hosts",
      "playbooks": [
        "infra/ansible/playbooks/forgejo-runner.yml"
      ],
      "dependencies": [
        "forgejo"
      ],
      "inventory": {
        "host": "forgejo_runner_lxc",
        "group": "forgejo_runner",
        "vmid_var": "forgejo_runner_vmid",
        "tf_vmid": "forgejo_runner_vmid",
        "tf_host": "forgejo_runner_ipv4_address",
        "extra_play_vars": {
          "forgejo_runner_pve_node_name": "proxmox_node_name"
        }
      },
      "terraform_module": "forgejo_runner"
    },
    "infisical": {
      "state_capable": false,
      "execution_resource": "direct_lxc_known_hosts",
      "conflicts": [
        "infisical_onramp"
      ],
      "playbooks": [
        "infra/ansible/playbooks/infisical.yml"
      ],
      "dependencies": [],
      "inventory": {
        "host": "infisical_lxc",
        "group": "infisical",
        "vmid_var": "infisical_vmid",
        "tf_vmid": "infisical_container_vmid",
        "tf_host": "infisical_lan_ip",
        "domain_var": "infisical_domain",
        "tf_domain": "infisical_server_name"
      },
      "terraform_module": "infisical"
    },
    "infisical_onramp": {
      "state_capable": true,
      "state_order": 5,
      "execution_resource": "onramp_host",
      "conflicts": [
        "infisical"
      ],
      "playbooks": [
        "infra/ansible/playbooks/infisical-onramp.yml"
      ],
      "dependencies": [
        "onramp_host"
      ],
      "inventory": {
        "host": "onramp_host_vm",
        "group": "onramp_host",
        "vmid_var": "onramp_host_vmid",
        "tf_vmid": "onramp_host_vmid",
        "tf_host": "onramp_host_ipv4_address",
        "domain_var": "infisical_domain",
        "tf_domain": "infisical_server_name",
        "user_var": "onramp_host_deploy_user",
        "tf_user": "onramp_host_deploy_user",
        "extra_play_vars": {
          "onramp_host_deploy_dir": "onramp_host_deploy_dir",
          "infisical_container_port": "infisical_container_port",
          "infisical_bind_address": "infisical_bind_address"
        }
      },
      "terraform_module": "onramp_host"
    },
    "hermes": {
      "execution_resource": "direct_lxc_known_hosts",
      "state_capable": true,
      "state_order": 1,
      "playbooks": [
        "infra/ansible/playbooks/hermes.yml"
      ],
      "dependencies": [],
      "inventory": {
